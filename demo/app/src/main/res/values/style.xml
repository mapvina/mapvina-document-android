<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- enable window content transitions -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="colorPrimary">@color/colorBlue</item>
        <item name="colorPrimaryDark">@color/colorBlue</item>
        <item name="colorAccent">@color/colorBlue</item>
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>
    </style>

    <style name="TextLabel" parent="Widget.Design.TextInputLayout">
        <!-- Hint color and label color in FALSE state -->
        <item name="android:textColorHint">@color/colorBlue</item>
        <item name="android:textSize">@dimen/_13ssp</item>
        <!-- Label color in TRUE state and bar color FALSE and TRUE State -->
        <item name="colorAccent">@color/colorBlack70</item>
        <item name="colorControlNormal">@color/colorBlack70</item>
        <item name="colorControlActivated">@color/colorBlack70</item>
    </style>

    <style name="edit_text_default" parent="text_default">
        <item name="android:lines">1</item>
        <item name="android:maxLines">1</item>
        <item name="android:lineSpacingExtra">@dimen/_5ssp</item>
        <item name="android:layout_height">@dimen/_40sdp</item>
        <item name="android:inputType">text</item>
        <item name="android:maxLength">128</item>
        <item name="android:paddingTop">@dimen/_10sdp</item>
        <item name="android:paddingBottom">@dimen/_10sdp</item>
        <item name="android:textColorHint">@color/colorBlue</item>
        <item name="android:paddingLeft">@dimen/_10sdp</item>
        <item name="android:paddingRight">@dimen/_10sdp</item>
<!--        <item name="android:background">@drawable/bg_edt</item>-->
    </style>

    <style name="edit_text_icon" parent="edit_text_default">
        <item name="android:paddingLeft">@dimen/_35sdp</item>
        <item name="android:paddingBottom">@dimen/_3sdp</item>
    </style>

    <style name="text_default10">
        <item name="android:textSize">@dimen/_10ssp</item>
        <item name="android:textColor">@color/colorBlackText</item>
    </style>  <!--TEXT-->
    <style name="text_default">
        <item name="android:textSize">@dimen/_12ssp</item>
        <item name="android:textColor">@color/colorBlackText</item>
    </style>

    <!--TEXTVIEW-->
    <style name="text_view_default" parent="text_default">
        <item name="android:lineSpacingExtra">@dimen/_3ssp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="text_view_default_size10" parent="text_default">
        <item name="android:lineSpacingExtra">@dimen/_3ssp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="TestNavigationViewDark" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/colorBlue</item>
        <item name="colorPrimaryDark">@color/colorBlue</item>
        <item name="colorAccent">@color/colorBlue</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <style name="TestNavigationViewLight" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorBlue</item>
        <item name="colorPrimaryDark">@color/colorBlue</item>
        <item name="colorAccent">@color/colorBlue</item>
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <style name="CustomMiniFloatingActionButton" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="android:layout_width">@dimen/_32sdp</item>
        <item name="android:layout_height">@dimen/_32sdp</item>
        <item name="fabCustomSize">@dimen/_32sdp</item>
        <item name="maxImageSize">@dimen/_18sdp</item>
        <item name="borderWidth">0dp</item>
        <item name="elevation">4dp</item>
        <item name="pressedTranslationZ">6dp</item>
        <item name="rippleColor">#33FFFFFF</item>
    </style>

    <style name="MapButton">
        <item name="android:background">@drawable/button_show_markers</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:foreground">@drawable/button_ripple_effect</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Shape appearance style for small FABs with white border -->
    <style name="ShapeAppearance.App.SmallComponent" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Style for map control floating action buttons -->
    <style name="MapControlFab" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="android:layout_width">@dimen/_24sdp</item>
        <item name="android:layout_height">@dimen/_24sdp</item>
        <item name="fabCustomSize">@dimen/_24sdp</item>
        <item name="maxImageSize">@dimen/_14sdp</item>
        <item name="android:layout_margin">2dp</item>
        <item name="fabSize">mini</item>
        <item name="backgroundTint">@android:color/white</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.SmallComponent</item>
        <item name="elevation">1dp</item>
        <item name="borderWidth">0dp</item>
    </style>

</resources>