<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow effect -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#22000000" /> <!-- Very light shadow -->
            <size
                android:width="64dp"
                android:height="64dp" />
        </shape>
    </item>
    
    <!-- Main circle with semi-transparent white background -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="oval">
            <solid android:color="#33FFFFFF" /> <!-- 20% white -->
            <stroke
                android:width="1dp"
                android:color="#55FFFFFF" /> <!-- 33% white border -->
            <size
                android:width="62dp"
                android:height="62dp" />
        </shape>
    </item>
</layer-list> 