<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer frame with 20% opacity -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#33FFFFFF" /> <!-- 20% white -->
            <size
                android:width="56dp"
                android:height="56dp" />
        </shape>
    </item>
    
    <!-- Middle circle with white border -->
    <item
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp"
        android:top="4dp">
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#33FFFFFF" /> <!-- 20% white -->
            <size
                android:width="48dp"
                android:height="48dp" />
        </shape>
    </item>
    
    <!-- Inner circle filled with green -->
    <item
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp">
        <shape android:shape="oval">
            <solid android:color="@color/colorGreen" />
            <size
                android:width="40dp"
                android:height="40dp" />
        </shape>
    </item>
</layer-list> 